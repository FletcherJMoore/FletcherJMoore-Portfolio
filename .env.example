# Copy this file to `.env` and fill in real values for local development.
# On Railway, set these in the app service's Variables tab instead.

# Postgres connection string.
# Local dev: paste your Railway Postgres "Public" connection URL here.
# On Railway: reference the DB service, e.g. ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Secret used to sign the auth session. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="generate-a-long-random-string"

# Google OAuth credentials (from Google Cloud Console → Credentials).
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# Comma-separated list of Google emails allowed into /admin.
# Optional — defaults to the owner's email if unset.
ADMIN_EMAILS="fletcherjmoore14@gmail.com"

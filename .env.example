# Copy this file to `.env` and fill in real values for local development.
# On Railway, set these in the app service's Variables tab instead.

# Postgres connection string.
# Local dev: paste your Railway Postgres "Public" connection URL here.
# On Railway: reference the DB service, e.g. ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Password you'll type to log in at /admin/login. Choose something strong.
ADMIN_PASSWORD="change-me-to-a-strong-password"

# Secret used to sign the admin session cookie. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="generate-a-long-random-string"
